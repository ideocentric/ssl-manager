# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is listed in .gitignore — never commit it.

# AWS region — run 'aws ec2 describe-regions --output table' for options
region = "us-east-1"

# Short prefix applied to all resource names
prefix = "ssl-manager"

# Instance type:
#   t3.small  (2 vCPU / 2 GB, x86_64) — recommended
#   t3.micro  (2 vCPU / 1 GB, x86_64) — minimum
#   t4g.small (2 vCPU / 2 GB, arm64)  — ~20% cheaper; change ami_arch to "arm64"
#   t4g.micro (2 vCPU / 1 GB, arm64)  — minimum ARM; change ami_arch to "arm64"
instance_type = "t3.small"

# Must match the instance type family:
#   "x86_64" for t3/t2, "arm64" for t4g
ami_arch = "x86_64"

# Linux admin username — Ubuntu AMIs use "ubuntu" by default
admin_username = "ubuntu"

# Paste the contents of your SSH public key (~/.ssh/id_ed25519.pub or ~/.ssh/id_rsa.pub)
admin_ssh_public_key = "ssh-ed25519 AAAAC3Nz... user@host"

# IP addresses allowed SSH access. Use /32 for single IPs.
# Add IPs here and run 'terraform apply' to update the security group — no rebuild needed.
allowed_ssh_ips = [
  "203.0.113.10/32",   # Office static IP
  # "198.51.100.5/32", # Home IP — uncomment to add
]

# Root EBS volume size in GB (30 GB is sufficient for <1000 certificates + 7-day backups)
root_volume_size_gb = 30

# System timezone — must be a valid tz database name.
# Controls log timestamps, backup filenames, and the 02:00 backup timer fire time.
# Run 'timedatectl list-timezones' for valid values.
# Examples: "America/New_York"  "America/Chicago"  "America/Los_Angeles"  "Europe/London"
timezone = "UTC"

# Tags applied to all resources
tags = {
  Project     = "ssl-manager"
  Environment = "production"
  ManagedBy   = "terraform"
}
