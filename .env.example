# Copy this file to .env — docker compose reads it automatically.
# .env is listed in .gitignore and will not be committed.

# System timezone for all containers.
# Must be a valid tz database name. Controls log timestamps and backup filenames.
# Leave as UTC if the server and your team are in different timezones.
# Examples: America/New_York  America/Chicago  America/Denver  America/Los_Angeles
#           Europe/London  Europe/Berlin  Asia/Tokyo  Australia/Sydney
TZ=UTC

# Flask secret key — change this before first use.
SECRET_KEY=change-me-in-production
