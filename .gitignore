# =============================================================================
# Secrets and local config
# =============================================================================

# Never commit credentials or local env overrides
.env
.env.*
*.pem
*.key

# Terraform — variable files contain SSH keys and IP addresses
deploy/azure/terraform.tfvars
deploy/azure/*.tfstate
deploy/azure/*.tfstate.backup
deploy/azure/.terraform/
deploy/azure/.terraform.lock.hcl
deploy/aws/terraform.tfvars
deploy/aws/*.tfstate
deploy/aws/*.tfstate.backup
deploy/aws/.terraform/
deploy/aws/.terraform.lock.hcl

